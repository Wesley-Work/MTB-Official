{
  "name": "mtb-official",
  "author": "Wesley",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:preview": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint:fix": "eslint --ext .vue,.js,.ts,.tsx ./src --max-warnings 0 --fix --cache",
    "lint": "pnpm lint:tsc && eslint --ext .vue,.js,.ts,.tsx ./src --max-warnings 0 --cache",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:update": "vitest run  -u && pnpm test:snap-update"
  },
  "dependencies": {
    "ngprogress": "^1.1.3",
    "path": "^0.12.7",
    "swiper": "^11.2.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vue": "^3.5.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.9",
    "@types/babel__traverse": "~7.20.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "22.5.1",
    "@types/raf": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^1.3.10",
    "@vitest/coverage-v8": "^3.0.7",
    "@vitest/ui": "^2.1.8",
    "@vue/babel-plugin-jsx": "1.2.2",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.14",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.7.1",
    "husky": "^7.0.4",
    "ignore": "^5.2.4",
    "jsdom": "^19.0.0",
    "less": "^4.2.2",
    "lint-staged": "^13.2.3",
    "lodash-es": "^4.17.21",
    "npm-run-all2": "^7.0.2",
    "prettier": "2.8.1",
    "sass-embedded": "^1.85.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7",
    "vue-tsc": "^2.2.4"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "prettier --write --cache",
      "eslint --fix --cache"
    ]
  }
}
